{
  "name": "@nexusrealm/utils",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint",
    "format": "prettier --write \"**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test"
  },
  "devDependencies": {
    "@nexusrealm/config": "workspace:*",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
